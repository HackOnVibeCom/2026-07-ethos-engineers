# --- Supabase (required) ---
# Create a free project at https://supabase.com, then Settings > API Keys
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# --- LLM provider: "gemini" (default, FREE), "anthropic", or "openai" ---
LLM_PROVIDER=gemini

# Gemini (free, no card): https://aistudio.google.com -> Get API key
GEMINI_API_KEY=your-gemini-key
# optional override, defaults to gemini-flash-latest (auto-tracks newest Flash)
# GEMINI_MODEL=gemini-flash-latest

# Anthropic (only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI or any OpenAI-compatible provider (only if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============ AUTOPILOT PUBLISHERS (each optional — configure any) ============

# Reddit: create a "script" app at https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=...
# REDDIT_CLIENT_SECRET=...
# REDDIT_USERNAME=your-reddit-username
# REDDIT_PASSWORD=your-reddit-password
# Post target — use YOUR OWN test subreddit, e.g. r/YourAppName (without r/)
# REDDIT_SUBREDDIT=YourTestSub

# Telegram: message @BotFather -> /newbot -> token. Add bot as admin to your
# channel; TELEGRAM_CHAT_ID is @yourchannelname (public) or numeric id.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=@yourchannel

# X / Twitter: developer.x.com -> app -> keys & tokens (free tier)
# TWITTER_APP_KEY=...
# TWITTER_APP_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_SECRET=...

# LinkedIn: developer.linkedin.com -> Create app -> Products tab -> add
# "Sign In with LinkedIn using OpenID Connect" AND "Share on LinkedIn"
# (both self-serve, instant, no review). Auth Settings tab -> add your
# redirect URL (must match LINKEDIN_REDIRECT_URI below exactly) -> copy
# Client ID/Secret. Unlike the others, this isn't "set env vars and go" —
# after setting these, click "Connect LinkedIn" in the app dashboard once to
# grant posting access (stored in Supabase, not env). Run supabase/linkedin.sql
# first.
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...
# LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# Discord: in your server, Channel Settings -> Integrations -> Webhooks ->
# New Webhook -> Copy URL. No OAuth, no review — works immediately.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Protects the Vercel cron endpoint (any random string)
# CRON_SECRET=change-me
